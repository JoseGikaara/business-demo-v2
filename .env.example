# ── Copy this file to .env.local and fill in your values ──────────────────────
# DO NOT commit .env.local to git

# Supabase — get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Places API — get from Google Cloud Console → Enable "Places API"
# This key goes into Vercel as GOOGLE_PLACES_KEY (NOT VITE_ prefix — it's server-side only)
GOOGLE_PLACES_KEY=your-google-places-key-here
